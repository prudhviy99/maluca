# Copy this to .env and adjust as needed.
# .env is gitignored — never commit actual values.

# Port the Maluca proxy listens on
PORT=8080

# Upstream backend base URL
UPSTREAM_URL=http://localhost:8081

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379

# Set to "true" only when Maluca sits behind a trusted load-balancer
# that correctly populates X-Forwarded-For. Spoofable otherwise.
TRUST_XFF=false
